# ============================================================
# Life OS — environment configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Required ---
# Long random string. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-use-a-long-random-string

# --- Paths (defaults work inside Docker) ---
VAULT_DIR=/app/vault
CONFIG_DIR=/app/config
FRONTEND_DIR=/app/frontend

# --- Cloudflare Tunnel ---
# Get this token from Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure
# The tunnel should have a Public Hostname pointing to http://backend:8000
# Cloudflare handles TLS automatically — no certs needed.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Timezone ---
# Use a tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# --- CORS ---
# Comma-separated list of allowed origins for the API.
# Set to your domain when deployed, e.g. https://lifeos.yourdomain.com
CORS_ORIGINS=https://lifeos.yourdomain.com

# --- VAPID Push Notifications ---
# Generate keys:
#   python -c "
#   from py_vapid import Vapid
#   v = Vapid()
#   v.generate_keys()
#   print('Private:', v.private_key.decode())
#   print('Public: ', v.public_key.decode())
#   "
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:you@example.com

# --- AI Suggestions ---
# Options: mistral | claude-code | disabled
AI_PROVIDER=disabled

# Mistral API (if AI_PROVIDER=mistral)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Claude Code CLI (if AI_PROVIDER=claude-code)
# Ensure `claude` binary is available in PATH inside the container.
# No extra config needed — uses the locally authenticated Claude Code session.

# --- Google Calendar ---
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Application type: Web application
# Authorised redirect URI: https://lifeos.yourdomain.com/api/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://lifeos.yourdomain.com/api/calendar/callback
# Comma-separated calendar IDs to check for free/busy (use 'primary' for main calendar)
GOOGLE_CALENDAR_IDS=primary
# Which calendar to write new events to
GOOGLE_CALENDAR_WRITE_ID=primary
